generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  employee
  admin
}

enum UserStatus {
  active
  disabled
}

model Organization {
  id            String             @id @default(cuid())
  name          String
  timezone      String             @default("America/Los_Angeles")
  weekStartDay  Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  memberships   OrganizationUser[]
  weekLocks     WeekLock[]
  appSessions   AppSession[]
  timeOffEntries TimeOffEntry[]
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  googleSub     String             @unique
  name          String?
  avatarUrl     String?
  status        UserStatus         @default(active)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  memberships   OrganizationUser[]
  sessions      TimeSession[]      @relation("SessionOwner")
  edits         TimeSession[]      @relation("SessionEditor")
  audits        AuditLog[]         @relation("AuditActor")
  lockedWeeks   WeekLock[]         @relation("LockActor")
  appSessions   AppSession[]
  preference    UserPreference?
}

model OrganizationUser {
  id                 String       @id @default(cuid())
  organizationId     String
  userId             String
  role               Role
  weeklyTargetMinute Int          @default(2400)
  active             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeSessions       TimeSession[]
  timeOffEntries     TimeOffEntry[]

  @@unique([organizationId, userId])
  @@index([organizationId, role])
  @@index([organizationId, active])
}

model TimeSession {
  id                 String           @id @default(cuid())
  organizationUserId String
  userId             String
  startAt            DateTime
  endAt              DateTime?
  editedById         String?
  editReason         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizationUser   OrganizationUser @relation(fields: [organizationUserId], references: [id], onDelete: Cascade)
  user               User             @relation("SessionOwner", fields: [userId], references: [id], onDelete: Cascade)
  editedBy           User?            @relation("SessionEditor", fields: [editedById], references: [id])

  @@index([organizationUserId, startAt])
  @@index([startAt])
  @@index([userId, endAt])
}

model WeekLock {
  id             String       @id @default(cuid())
  organizationId String
  weekStart      DateTime
  lockedAt       DateTime     @default(now())
  lockedByUserId String?
  autoLocked     Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lockedBy       User?        @relation("LockActor", fields: [lockedByUserId], references: [id])

  @@unique([organizationId, weekStart])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId, createdAt])
}

model AppSession {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  tokenHash      String       @unique
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  revokedAt      DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, expiresAt])
  @@index([organizationId, expiresAt])
  @@index([expiresAt])
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  timezone  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TimeOffEntry {
  id                 String           @id @default(cuid())
  organizationId     String
  organizationUserId String
  date               DateTime
  type               String
  status             String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationUser   OrganizationUser @relation(fields: [organizationUserId], references: [id], onDelete: Cascade)

  @@unique([organizationUserId, date])
  @@index([organizationId, date])
}


model CalendarConnection {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  calendarId     String   @default("primary")
  accessToken    String?
  refreshToken   String?
  scope          String?
  tokenExpiresAt DateTime?
  status         String   @default("active")
  lastError      String?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model TimeOffCalendarSync {
  id              String   @id @default(cuid())
  timeOffEntryId  String
  userId          String
  provider        String
  calendarId      String?
  externalEventId String?
  syncStatus      String   @default("pending")
  lastSyncedAt    DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([timeOffEntryId, provider])
  @@index([userId, syncStatus, updatedAt])
}
